pipeline {
    agent any

    parameters {
        string(
            name: 'CONTROL_NODE_IP',
            defaultValue: '',
            description: 'Private IP of the Ansible Control Node (from terraform output control_node_private_ip)'
        )
    }

    environment {
        ANSIBLE_DIR = "/home/ubuntu/cicd-eks-pipeline/ansible"
    }

    stages {
        stage('Update Playbooks') {
            steps {
                sh '''
                    ssh -o StrictHostKeyChecking=no ubuntu@${CONTROL_NODE_IP} \
                        "git -C /home/ubuntu/cicd-eks-pipeline pull --ff-only"
                '''
            }
        }

        stage('Configure Agent') {
            steps {
                sh '''
                    ssh -o StrictHostKeyChecking=no ubuntu@${CONTROL_NODE_IP} \
                        "cd ${ANSIBLE_DIR} && \
                         ansible-playbook \
                         -e @group_vars/all.yml \
                         playbooks/agent.yml"
                '''
            }
        }

        stage('Configure SonarQube') {
            steps {
                sh '''
                    ssh -o StrictHostKeyChecking=no ubuntu@${CONTROL_NODE_IP} \
                        "cd ${ANSIBLE_DIR} && \
                         ansible-playbook \
                         -e @group_vars/all.yml \
                         playbooks/sonarqube.yml"
                '''
            }
        }
    }

    post {
        success {
            echo 'Infrastructure configuration complete. All servers are ready.'
        }
        failure {
            echo 'Infrastructure configuration failed. Check the logs above.'
        }
    }
}
